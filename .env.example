# USTA Scraper Configuration

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=usta_tennis
DB_USER=usta_app
DB_PASSWORD=usta_password

# USTA Account Credentials (member login)
USTA_EMAIL=your-email@example.com
USTA_PASSWORD=your-password-here

# Scraper Settings
SCRAPE_HEADLESS=true
SCRAPE_PAGE_DELAY=2.5
SCRAPE_TIMEOUT=30000
SCRAPE_RETRIES=3
SCRAPE_DEBUG_DIR=~/.usta-scraper/debug
SCRAPE_STATE_DIR=~/.usta-scraper/browser-state

# Scheduler Intervals (seconds)
SCHEDULE_PLAYER_REFRESH=21600
SCHEDULE_RANKING_SNAPSHOT=86400
SCHEDULE_TOURNAMENT_LIST=3600
SCHEDULE_JOB_POLL=30
